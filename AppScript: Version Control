function copyToGOBJune() {

  // ✅ GOB June (TARGET)
  const gobSS = SpreadsheetApp.openById(
    "1dswFay7N4WwYrzhvWhkt2GsxKCmRQN46s9hpx1TiWQw"//change every month
  );

  // ✅ Master Call Log (SOURCE)
  const sourceSS = SpreadsheetApp.openById(
    "1OCfHIpHX7ARgATlY5MQQXcj18DzritahAk3mILU_0hs"
  );

  const sourceSheet = sourceSS.getSheetByName("July 2026"); // change every month

  // ✅ Cover File (controls sheet name)
  const coverSS = SpreadsheetApp.openById(
    "1CrVRpSUoKglgC87qChfN5f9tuO0jBD-wl9qW3HSx1EE"
  );

  const coverSheet = coverSS.getSheetByName("Cover");

  if (!coverSheet) {
    throw new Error('Cover sheet not found.');
  }

  // ✅ Get sheet name from C4
  let newSheetName = coverSheet.getRange("C4").getValue();

  if (!newSheetName) {
    throw new Error('Cover!C4 is empty.');
  }

  // ✅ Convert to string (avoids errors if number/date)
  newSheetName = newSheetName.toString().trim();

  // ✅ Prevent invalid sheet name characters
  newSheetName = newSheetName.replace(/[\\\/\?\*\[\]]/g, "");

  // ✅ Check if sheet already exists
  const existingSheet = gobSS.getSheetByName(newSheetName);
  if (existingSheet) {
    throw new Error(`Sheet "${newSheetName}" already exists.`);
  }

  // ✅ Create new tab
  const targetSheet = gobSS.insertSheet(newSheetName);

  // ✅ Get data from source
  const lastRow = sourceSheet.getLastRow();
  const data = sourceSheet.getRange(`A1:Z${lastRow}`).getValues();

  if (data.length === 0) {
    throw new Error("No data found to copy.");
  }

  // ✅ Paste into new sheet
  targetSheet
    .getRange(1, 1, data.length, data[0].length)
    .setValues(data);

  SpreadsheetApp.getUi().alert(
    `✅ Data copied to GOB July → ${newSheetName}` //change every month
  );
coverSheet.getRange("D11").setValue("OK");

}
